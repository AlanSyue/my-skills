ATLASSIAN_BASE_URL=https://xxx.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace_me

# Bitbucket Cloud App Password (create at: https://bitbucket.org/account/settings/app-passwords/)
# Required scopes: Account: Read, Pull requests: Read, Pull requests: Write
BITBUCKET_API_TOKEN=replace_me
# Optional: set this if your App Password lacks Account: Read scope
# BITBUCKET_ACCOUNT_ID=

ASANA_ACCESS_TOKEN=replace_me
ASANA_WORKSPACE_GID=replace_me
ASANA_DONE_SECTION_NAME="to be test"

# Google Slides (used by markdown-to-slides skill)
# Supports two credential types:
#   1. Service Account: download JSON key from GCP Console > IAM > Service Accounts
#   2. OAuth2 Desktop: download JSON from GCP Console > APIs & Credentials > OAuth 2.0 Client IDs (type: Desktop)
# The script auto-detects the credential type from the JSON file.
GOOGLE_CREDENTIALS_FILE=/path/to/credentials.json
GOOGLE_SLIDES_SHARE_EMAIL=user@example.com
